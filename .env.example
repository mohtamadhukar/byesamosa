# ByeSamosa Environment Configuration
# Copy this file to .env and fill in your values.

# --- Anthropic API ---
# Required for AI-generated health insights (Claude API).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Oura Account ---
# Email address for your Oura account. Required for the `pull` command
# (Playwright browser automation to download exports).
OURA_EMAIL=your-email@example.com

# --- Gmail OTP Proxy ---
# Used by the `pull` command to retrieve Oura login OTP codes via IMAP.
# Set up a dedicated Gmail account and enable an App Password (16-char).
# Both must be set together, or both left empty.
GMAIL_OTP_EMAIL=your-otp-proxy@gmail.com
GMAIL_OTP_APP_PASSWORD=your-16-char-app-password
